1	<!DOCTYPE html>
2	<html lang="id">
3	<head>
4	<meta charset="UTF-8">
5	<meta name="viewport" content="width=device-width, initial-scale=1.0">
6	
7	<title>PT Chevron Pacific Indonesia</title>
8	
9	<meta name="description" content="PT Chevron Pacific Indonesia - Solusi Energi, Minyak, Gas dan Teknologi Industri di Indonesia.">
10	<meta name="keywords" content="Chevron, Chevron Indonesia, Minyak, Gas, Energi, Industri, Engineering">
11	<meta name="author" content="PT Chevron Pacific Indonesia">
12	
13	<link rel="preconnect" href="https://fonts.googleapis.com">
14	<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
15	
16	<style>
17	
18	*{
19	    margin:0;
20	    padding:0;
21	    box-sizing:border-box;
22	    font-family:'Poppins',sans-serif;
23	}
24	
25	body{
26	    background:#f8f9fa;
27	    color:#222;
28	    line-height:1.6;
29	}
30	
31	/* HEADER */
32	
33	header{
34	    position:fixed;
35	    width:100%;
36	    top:0;
37	    left:0;
38	    z-index:1000;
39	    background:#ffffff;
40	    box-shadow:0 2px 15px rgba(0,0,0,.08);
41	}
42	
43	.container{
44	    width:90%;
45	    max-width:1200px;
46	    margin:auto;
47	}
48	
49	.navbar{
50	    display:flex;
51	    justify-content:space-between;
52	    align-items:center;
53	    padding:18px 0;
54	}
55	
56	.logo{
57	    display:flex;
58	    align-items:center;
59	    gap:10px;
60	    font-size:22px;
61	    font-weight:700;
62	    color:#0057B8;
63	}
64	
65	.logo img{
66	    width:45px;
67	    height:auto;
68	    display:block;
69	}
70	
71	.logo span{
72	    color:#0057B8;
73	}
74	
75	nav ul{
76	    list-style:none;
77	    display:flex;
78	    gap:25px;
79	}
80	
81	nav ul li a{
82	    text-decoration:none;
83	    color:#333;
84	    font-weight:500;
85	    transition:.3s;
86	}
87	
88	nav ul li a:hover{
89	    color:#0057B8;
90	}
91	
92	/* HERO */
93	
94	.hero{
95	    height:100vh;
96	    background:
97	    linear-gradient(rgba(0,0,0,.55),
98	    rgba(0,0,0,.55)),
99	    url('https://images.unsplash.com/photo-1513828583688-c52646db42da?q=80&w=1920');
100	    background-size:cover;
101	    background-position:center;
102	    display:flex;
103	    align-items:center;
104	    color:white;
105	}
106	
107	.hero-content{
108	    max-width:700px;
109	}
110	
111	.hero h1{
112	    font-size:58px;
113	    margin-bottom:15px;
114	}
115	
116	.hero p{
117	    font-size:18px;
118	    margin-bottom:25px;
119	}
120	
121	.btn{
122	    display:inline-block;
123	    padding:14px 30px;
124	    background:#E31E24;
125	    color:white;
126	    text-decoration:none;
127	    border-radius:5px;
128	    transition:.3s;
129	}
130	
131	.btn:hover{
132	    background:#c3171d;
133	}
134	
135	/* SECTION */
136	
137	section{
138	    padding:90px 0;
139	}
140	
141	.section-title{
142	    text-align:center;
143	    margin-bottom:50px;
144	}
145	
146	.section-title h2{
147	    color:#0057B8;
148	    font-size:38px;
149	}
150	
151	.about-grid{
152	    display:grid;
153	    grid-template-columns:1fr 1fr;
154	    gap:40px;
155	    align-items:center;
156	}
157	
158	.about img{
159	    width:100%;
160	    border-radius:10px;
161	}
162	
163	.services-grid{
164	    display:grid;
165	    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
166	    gap:25px;
167	}
168	
169	.service{
170	    background:white;
171	    padding:30px;
172	    border-radius:10px;
173	    box-shadow:0 5px 15px rgba(0,0,0,.08);
174	    transition:.3s;
175	}
176	
177	.service:hover{
178	    transform:translateY(-8px);
179	}
180	
181	.service h3{
182	    color:#0057B8;
183	    margin-bottom:10px;
184	}
185	
186	/* STATS */
187	
188	.stats{
189	    background:#0057B8;
190	    color:white;
191	}
192	
193	.stats-grid{
194	    display:grid;
195	    grid-template-columns:repeat(4,1fr);
196	    text-align:center;
197	    gap:20px;
198	}
199	
200	.stats h3{
201	    font-size:42px;
202	}
203	
204	/* CONTACT */
205	
206	.contact{
207	    background:#fff;
208	}
209	
210	.contact-form{
211	    max-width:700px;
212	    margin:auto;
213	}
214	
215	.contact-form input,
216	.contact-form textarea{
217	    width:100%;
218	    padding:15px;
219	    margin-bottom:15px;
220	    border:1px solid #ddd;
221	    border-radius:5px;
222	}
223	
224	.contact-form button{
225	    border:none;
226	    cursor:pointer;
227	}
228	
229	/* FOOTER */
230	
231	footer{
232	    background:#111;
233	    color:#ccc;
234	    text-align:center;
235	    padding:25px;
236	}
237	
238	@media(max-width:768px){
239	
240	.hero h1{
241	    font-size:40px;
242	}
243	
244	.about-grid{
245	    grid-template-columns:1fr;
246	}
247	
248	.stats-grid{
249	    grid-template-columns:repeat(2,1fr);
250	}
251	
252	nav{
253	    display:none;
254	}
255	
256	}
257	</style>
258	</head>
